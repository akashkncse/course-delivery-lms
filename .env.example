# =============================================================================
# Course Delivery LMS — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# Neon PostgreSQL connection string
# Get one free at https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xyz.us-east-2.aws.neon.tech/lms?sslmode=require

# -----------------------------------------------------------------------------
# SMTP / Email (Required)
# -----------------------------------------------------------------------------
# Used for sending OTP verification and password-reset emails.
# For Gmail: enable 2FA and generate an App Password at
# https://myaccount.google.com/apppasswords
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# -----------------------------------------------------------------------------
# Razorpay — Payment Processing (Optional)
# -----------------------------------------------------------------------------
# If not set, the app falls back to a test/simulated checkout mode.
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here
# Client-side key used by the Razorpay checkout modal (same value as RAZORPAY_KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx

# -----------------------------------------------------------------------------
# Vercel Blob — File Uploads (Optional)
# -----------------------------------------------------------------------------
# Required for file/image uploads. Obtain from the Vercel dashboard:
# https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx

# -----------------------------------------------------------------------------
# Admin Seed Script (Scripts only)
# -----------------------------------------------------------------------------
# Used by `scripts/seed-admin.ts` to create the initial superadmin user.
# These are only needed when running the seed script, not at runtime.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password
